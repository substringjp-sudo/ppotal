{
  "name": "functions",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=lib/index.js --external:firebase-admin --external:firebase-functions --external:node-fetch --external:topojson-client",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "verify": "ts-node scripts/verify-functions.ts"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "node-fetch": "^2.7.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@types/topojson-client": "^3.1.5",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "esbuild": "^0.25.0"
  },
  "private": true
}
