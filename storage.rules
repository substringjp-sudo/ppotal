rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User-specific folders: owners can read/write
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Travelog assets: anyone can read, owner can write
    match /travelogs/{travelogId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        firestore.get(/databases/(default)/documents/travelogs/$(travelogId)).data.userId == request.auth.uid;
    }

    // Trip assets: anyone can read, owners and members can write
    match /trips/{tripId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        firestore.get(/databases/(default)/documents/trips/$(tripId)).data.userId == request.auth.uid ||
        request.auth.uid in firestore.get(/databases/(default)/documents/trips/$(tripId)).data.get('members', [])
      );
    }

    // Static data files (region, airport, airlines, routes)
    // Write is done via Admin SDK in scripts/upload_data_to_storage.py
    match /data/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // MVT Tiles
    match /tiles/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }


    // Temp uploads for photo wizard (Uploader only)
    match /temp_uploads/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Public read, admin-only write for other paths
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
